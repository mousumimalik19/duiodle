# =============================================================================
# DUIODLE BACKEND CONFIGURATION
# =============================================================================
# Copy this file to .env and fill in your values
# NEVER commit .env to version control!
# =============================================================================

# -----------------------------------------------------------------------------
# Project Settings
# -----------------------------------------------------------------------------
PROJECT_NAME=Duiodle
DEBUG_MODE=false
ENVIRONMENT=development  # development, staging, production, testing

# -----------------------------------------------------------------------------
# API Keys (REQUIRED for real AI vision processing)
# -----------------------------------------------------------------------------

# OpenAI GPT-4o Vision
# Get your key: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Google Gemini 2.0 Flash
# Get your key: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=

# -----------------------------------------------------------------------------
# Vision Provider Selection
# -----------------------------------------------------------------------------
# Options:
#   - mock:   Uses OpenCV (FREE, good for development)
#   - openai: Uses GPT-4o Vision API (requires OPENAI_API_KEY)
#   - gemini: Uses Gemini 2.0 Flash API (requires GEMINI_API_KEY)

VISION_PROVIDER=mock

# Model configuration
VISION_MODEL_OPENAI=gpt-4o
VISION_MODEL_GEMINI=gemini-2.0-flash-exp
VISION_MAX_TOKENS=4096
VISION_TEMPERATURE=0.1

# -----------------------------------------------------------------------------
# CORS Settings (for React frontend)
# -----------------------------------------------------------------------------
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# -----------------------------------------------------------------------------
# Upload Settings
# -----------------------------------------------------------------------------
MAX_UPLOAD_SIZE_MB=10
UPLOAD_DIR=/tmp/duiodle_uploads
ALLOWED_EXTENSIONS=.png,.jpg,.jpeg,.webp,.gif

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
LOG_LEVEL=INFO  # DEBUG, INFO, WARNING, ERROR, CRITICAL

# -----------------------------------------------------------------------------
# Server Settings
# -----------------------------------------------------------------------------
HOST=0.0.0.0
PORT=8000
